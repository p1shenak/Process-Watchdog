<Window x:Class="ProcessWatchdog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Watchdog v1.7 - p1shenak" Height="750" Width="1100" Background="#121212">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Обновить" Click="RefreshBtn_Click" Width="100" Height="30" Background="#333" Foreground="White" BorderThickness="0"/>
            <CheckBox x:Name="AutoRefreshCb" Content="Авто-обновление (5с)" Foreground="#AAA" Margin="15,0,0,0" VerticalAlignment="Center" Checked="AutoRefresh_Toggle" Unchecked="AutoRefresh_Toggle"/>
            <CheckBox x:Name="HideSystemCb" Content="Скрыть системные" Foreground="#AAA" Margin="15,0,0,0" VerticalAlignment="Center" Checked="RefreshBtn_Click" Unchecked="RefreshBtn_Click"/>
            <Button Content="Проверить обновления" Click="CheckUpdates_Click" Margin="20,0,0,0" Width="160" Height="30" Background="#1A331A" Foreground="#00FF00" BorderBrush="#00FF00"/>
        </StackPanel>

        <TextBox x:Name="SearchBox" Grid.Row="1" Height="30" Margin="0,0,0,10" Background="#1A1A1A" Foreground="White" 
                 BorderBrush="#333" Padding="10,5" TextChanged="SearchBox_TextChanged" Tag="Поиск по названию..."/>

        <ListView x:Name="ProcessList" Grid.Row="2" Background="#1A1A1A" Foreground="#DDD" BorderThickness="0">
            <ListView.ContextMenu>
                <ContextMenu Background="#222" Foreground="White">
                    <MenuItem Header="Завершить процесс" Click="KillProcess_Click" FontWeight="Bold"/>
                    <Separator Background="#444"/>
                    <MenuItem Header="Приостановить (Freeze)" Click="SuspendProcess_Click"/>
                    <MenuItem Header="Возобновить (Resume)" Click="ResumeProcess_Click"/>
                    <Separator Background="#444"/>
                    <MenuItem Header="Проверить на VirusTotal" Click="CheckVirusTotal_Click"/>
                    <MenuItem Header="Открыть папку" Click="OpenFileLocation_Click"/>
                    <MenuItem Header="Снять критичность" Click="AddSelectedToExclusions_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Название" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" Foreground="{Binding Color}" FontWeight="Bold" FontFamily="Consolas"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="PID" DisplayMemberBinding="{Binding Id}" Width="70"/>
                    <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding Status}" Width="120"/>
                    <GridViewColumn Header="Путь к файлу" DisplayMemberBinding="{Binding Path}" Width="550"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,15,0,0">
            <Button Content="Завершить процесс" Click="KillProcess_Click" Width="160" Height="35" Background="#441111" Foreground="White" FontWeight="Bold"/>
            <Button Content="Добавить исключение" Click="AddManualExclusion_Click" Width="180" Height="35" Background="#114411" Foreground="White" FontWeight="Bold" Margin="15,0,0,0"/>
            <TextBlock x:Name="StatusLabel" Text="Готов" Foreground="#555" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>