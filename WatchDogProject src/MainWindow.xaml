<Window x:Class="ProcessWatchdog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Watchdog" Height="500" Width="950" Background="#1E1E1E">
    <Grid>
        <DockPanel Margin="10">
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnDisableCritical" Content="Снять критичность" Width="150" Height="30" Margin="5" Click="BtnDisableCritical_Click" Background="#333" Foreground="White"/>
                <Button x:Name="BtnKill" Content="Завершить процесс" Width="150" Height="30" Margin="5" Background="#742A2A" Foreground="White" Click="BtnKill_Click"/>
            </StackPanel>
            <ListView x:Name="ProcessList" Background="#252526" Foreground="White">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Имя" DisplayMemberBinding="{Binding Name}" Width="150"/>
                        <GridViewColumn Header="PID" DisplayMemberBinding="{Binding Id}" Width="70"/>
                        <GridViewColumn Header="Статус" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" FontWeight="Bold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Путь" DisplayMemberBinding="{Binding Path}" Width="450"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>
    </Grid>
</Window>