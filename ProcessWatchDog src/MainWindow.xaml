<Window x:Class="ProcessWatchdog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Watchdog v1.5 - p1shenak" Height="700" Width="1000" Background="#121212">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
            <Button Content="Обновить список" Click="RefreshBtn_Click" Width="120" Height="30" Background="#333" Foreground="White" BorderThickness="0"/>
            <CheckBox x:Name="HideSystemCb" Content="Скрыть проверенные системные" Foreground="#AAA" Margin="20,0,0,0" VerticalAlignment="Center" Checked="HideSystemCb_Checked" Unchecked="HideSystemCb_Unchecked"/>
            <Button Content="Проверить обновления" Click="CheckUpdates_Click" Margin="20,0,0,0" Width="160" Height="30" Background="#1A331A" Foreground="#00FF00" BorderBrush="#00FF00"/>
        </StackPanel>

        <ListView x:Name="ProcessList" Grid.Row="1" Background="#1A1A1A" Foreground="#DDD" BorderThickness="0">
            <ListView.ContextMenu>
                <ContextMenu Background="#222" Foreground="White">
                    <MenuItem Header="Завершить процесс" Click="KillProcess_Click"/>
                    <MenuItem Header="Добавить в исключения" Click="AddManualExclusion_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Название" Width="180">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Foreground="{Binding Color}" FontWeight="Bold" FontFamily="Consolas"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="PID" DisplayMemberBinding="{Binding Id}" Width="70"/>
                    <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding Status}" Width="130"/>
                    <GridViewColumn Header="Путь к файлу" DisplayMemberBinding="{Binding Path}" Width="500"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,15,0,0">
            <Button Content="Завершить процесс" Click="KillProcess_Click" Width="160" Height="35" Background="#441111" Foreground="White" FontWeight="Bold" Margin="0,0,15,0"/>
            <Button Content="Добавить исключение" Click="AddManualExclusion_Click" Width="180" Height="35" Background="#114411" Foreground="White" FontWeight="Bold"/>
            <TextBlock Text="Правый клик по процессу для меню" Foreground="#555" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>